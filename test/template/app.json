{
  "expo": {
    "name": "TestCodePush",
    "slug": "TestCodePush",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.testcodepush"
    },
    "android": {
      "package": "com.testcodepush"
    },
    "plugins": [
      [
        "@code-push-next/react-native-code-push/expo",
        {
          "ios": {
            "CodePushDeploymentKey": "mock-ios-deployment-key",
            "CodePushServerURL": "http://127.0.0.1:3000"
          },
          "android": {
            "CodePushDeploymentKey": "mock-android-deployment-key",
            "CodePushServerURL": "http://10.0.2.2:3001"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ]
    ]
  }
}
